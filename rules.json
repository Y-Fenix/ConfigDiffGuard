{
  "include": [
    "*.csv",
    "*.tsv",
    "*.json",
    "**/*.csv",
    "**/*.tsv",
    "**/*.json"
  ],
  "exclude": [
    "**/.git/**",
    "**/Library/**",
    "**/Temp/**",
    "**/Logs/**",
    "**/Build/**",
    "**/Builds/**",
    "**/obj/**",
    "**/bin/**",
    "**/node_modules/**",
    "**/Packages/**",
    "**/ProjectSettings/**",
    "**/UserSettings/**",
    "**/Plugins/**",
    "**/*.meta"
  ],
  "max_details_per_table": 500,
  "max_total_details": 20000,
  "tables": [
    {
      "pattern": "**/*.csv",
      "primary_key": [],
      "important_fields": {},
      "field_rules": []
    },
    {
      "pattern": "**/*.json",
      "primary_key": [],
      "important_fields": {},
      "field_rules": []
    }
  ]
}
