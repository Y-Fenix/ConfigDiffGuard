{
  "version": 1,
  "description": "配置文件来源模板。复制为 studio_config_sources.json 后，按你的组织、项目和配置目录调整。",
  "usage_note": "此文件只描述去哪里找配置、支持哪些格式；字段校验和风险规则由 rules.json 负责。",
  "default_studio": "示例工作室",
  "studios": [
    {
      "name": "示例工作室",
      "org_id": "your-remote-workspace-or-organization-id",
      "namespace_id": "optional-namespace-id",
      "config_sources": [
        {
          "name": "Unity LevelData CSV",
          "formats": [
            "csv"
          ],
          "include": [
            "LevelData/**/*.csv",
            "Assets/LevelData/**/*.csv",
            "Assets/Resources/LevelData/**/*.csv",
            "*/LevelData/**/*.csv",
            "*/Assets/LevelData/**/*.csv",
            "*/Assets/Resources/LevelData/**/*.csv"
          ],
          "exclude": [
            "**/.git/**",
            "**/Library/**",
            "**/Temp/**",
            "**/Logs/**",
            "**/Build/**",
            "**/obj/**",
            "**/node_modules/**"
          ],
          "normalize_from": "LevelData"
        },
        {
          "name": "JSON Config",
          "formats": [
            "json"
          ],
          "include": [
            "Config/**/*.json",
            "Assets/Resources/Data/**/*.json",
            "*/Assets/Resources/Data/**/*.json"
          ],
          "exclude": [
            "**/.git/**",
            "**/Library/**",
            "**/Temp/**",
            "**/Logs/**",
            "**/Build/**",
            "**/obj/**",
            "**/node_modules/**",
            "**/package*.json"
          ],
          "normalize_from": [
            "Config",
            "Data"
          ]
        }
      ],
      "project_overrides": {
        "ExampleProject": {
          "note": "当某个项目的配置路径不符合工作室默认规则时，在这里单独覆盖。",
          "formats": [
            "csv",
            "json"
          ],
          "include": [
            "ExampleProject/Assets/GameData/**/*.csv",
            "ExampleProject/Assets/GameData/**/*.json"
          ],
          "normalize_from": [
            "GameData"
          ]
        }
      }
    }
  ]
}
