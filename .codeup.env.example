export YUNXIAO_TOKEN="在这里填你的云效/Codeup个人访问令牌"
export YUNXIAO_ORGANIZATION_ID="your-codeup-organization-id"
export YUNXIAO_ORGANIZATIONS="示例组织=your-codeup-organization-id#optional-namespace-id"
# 如果云效 Token 是按组织隔离的，也可以给每个工作室单独配 token：
# export YUNXIAO_ORGANIZATIONS="组织A=organization-id-a#namespace-id-a|token-a,组织B=organization-id-b#namespace-id-b|token-b"
export YUNXIAO_DOMAIN="openapi-rdc.aliyuncs.com"

# 商业化多平台模式推荐：
# 1. 复制 provider_accounts.example.json 为 provider_accounts.json
# 2. 在 provider_accounts.json 中配置 GitHub / Codeup 等平台账号
# 3. token 可直接写 token，也更推荐写 token_env，然后在这里导出环境变量
export GITHUB_TOKEN="在这里填你的 GitHub Personal Access Token"
export GITLAB_TOKEN="在这里填你的 GitLab Personal/Project/Group Access Token"
export GITEE_TOKEN="在这里填你的 Gitee 私人令牌"
export BITBUCKET_USERNAME="在这里填你的 Bitbucket 用户名"
export BITBUCKET_APP_PASSWORD="在这里填你的 Bitbucket App Password"
