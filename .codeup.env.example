# Optional: Codeup/Yunxiao remote repository access.
# Copy this file to .codeup.env and fill in your own values.

export YUNXIAO_TOKEN="your_personal_access_token"
export YUNXIAO_ORGANIZATION_ID="your_organization_id"

# Optional multiple organizations:
# Format:
#   DisplayName=organization_id#namespace_id
#   DisplayName=organization_id#namespace_id|organization_specific_token
export YUNXIAO_ORGANIZATIONS="StudioA=organization_id_a#namespace_id_a,StudioB=organization_id_b#namespace_id_b"

export YUNXIAO_DOMAIN="openapi-rdc.aliyuncs.com"
